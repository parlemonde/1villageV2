  "scripts": {
    "dev:next": "next dev",
    "dev:services": "docker compose up",
    "dev:email": "email dev --port 3001 --dir ./src/server/emails/templates",
    "dev": "concurrently --names nextjs,docker -c green,blue --kill-others-on-fail \"pnpm run dev:next\" \"pnpm run dev:services\"",
    "build": "next build",
    "build:lambda": "rm -rf .open-next && open-next build --config-path ./open-next/open-next.config.ts && node ./open-next/install-deps.mjs",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test:unit": "jest",
    "typecheck": "next typegen && tsc --noEmit -p .",
    "db:migrate": "dotenvx run -- tsx src/server/database/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "i18n:extract": "tsx src/server/i18n/extract.mts"
  },
